# サーバー設定
PORT=4000

# JWT 署名鍵 (本番では必ず十分にランダムな値へ変更してください)
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=12h

# CORS 許可オリジン (カンマ区切り)
CLIENT_ORIGIN=http://localhost:5173

# データベース
# 開発は SQLite。将来 PostgreSQL へ移行する場合は DB_CLIENT=pg として
# DATABASE_URL を設定してください (knexfile.ts 参照)。
DB_CLIENT=better-sqlite3
DB_FILE=./data/kpi.sqlite
# DATABASE_URL=postgres://user:pass@localhost:5432/kpi

# Google ログイン (OAuth クライアントID)。未設定なら Google ログインは無効。
GOOGLE_CLIENT_ID=

# 名簿(Googleシート)。CSV公開エクスポートで読み込む。
ROSTER_SHEET_ID=1ya61d3P2cWppsnrXnQCLMNAeOrobtqitRze-Q5chgHA
ROSTER_SHEET_GID=
