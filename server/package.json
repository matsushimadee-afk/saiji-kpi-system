{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "KPI管理システム バックエンド (Express + Socket.io + Knex)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "migrate": "tsx src/db/cli.ts migrate",
    "seed": "tsx src/db/cli.ts seed",
    "db:reset": "tsx src/db/cli.ts reset",
    "sync:roster": "tsx src/scripts/syncRoster.ts",
    "sample:entries": "tsx src/scripts/sampleEntries.ts"
  },
  "dependencies": {
    "@saiji/shared": "1.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "google-auth-library": "^9.14.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
