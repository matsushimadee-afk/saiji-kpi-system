# 本番用 環境変数のテンプレート。
# これを server/.env としてコピーし、値を埋めてください。

PORT=4000
NODE_ENV=production
SERVE_CLIENT=true

# 十分に長いランダム文字列に置き換える（生成例: openssl rand -hex 32）
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHARS
JWT_EXPIRES_IN=12h

# 公開ドメイン（https）
CLIENT_ORIGIN=https://your-domain.example.com

# DB（VMのディスクに永続化される SQLite）
DB_CLIENT=better-sqlite3
DB_FILE=./data/kpi.sqlite

# Google ログイン（Google Cloud で作成した OAuth クライアントID）
GOOGLE_CLIENT_ID=

# 名簿(Googleシート)
ROSTER_SHEET_ID=1ya61d3P2cWppsnrXnQCLMNAeOrobtqitRze-Q5chgHA
ROSTER_SHEET_GID=
